# SiliconFlow API — Phase 5-P4
#
# ⚠️  NEVER COMMIT A REAL KEY. This file is the template.
#     Copy to `.env` (gitignored) and fill in your real key there, or
#     set SILICONFLOW_API_KEY in your shell via direnv / dotenv / exports.
#
# Get a key at: https://cloud.siliconflow.cn/account/ak

# ─────────────────────────────────────────────────────────────────
# REQUIRED: SiliconFlow Bearer token
# ─────────────────────────────────────────────────────────────────
SILICONFLOW_API_KEY=sk-REPLACE-WITH-YOUR-REAL-KEY

# ─────────────────────────────────────────────────────────────────
# OPTIONAL: override defaults (matches rag-app/application.yml)
# ─────────────────────────────────────────────────────────────────

# Set to "true" to activate the SiliconFlow adapters.
# When false (or unset), the stub adapters in rag-embedding/stub/* are used.
RAG_SILICONFLOW_ENABLED=false

# API base URL — change if SiliconFlow moves their endpoint.
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Embedding — defaults are tuned for BAAI/bge-m3 (1024-dim).
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_EMBEDDING_DIM=1024

# Rerank — BAAI/bge-reranker-v2-m3 pairs well with bge-m3 embeddings.
SILICONFLOW_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# LLM — Qwen/Qwen2.5-7B-Instruct is the lowest-cost tier.
# Swap to Qwen/Qwen2.5-32B-Instruct or Qwen/Qwen3-8B if you need more quality.
SILICONFLOW_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct