<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback config for rag-app (Spring Boot 3.x).

  Two modes, switched by env var `LOG_FORMAT`:
    - `console` (default): human-readable, MDC fields rendered inline:
        2026-06-17 18:00:00.123  INFO [tenant=acme] [reqId=...] [jobId=j-abc] [stage=embed]
        io.github.yysf1949.rag.pipeline.qa.QAServiceImpl : QA cache HIT ...
    - `json` (set LOG_FORMAT=json): machine-readable, one event per line.
      Used when log shipping (Loki / Splunk / DataDog) consumes stdout.

  MDC keys (set by PipelineMdc + MdcTenantFilter):
    tenant      → tenant id (e.g. "acme", "tenant-A")
    requestId   → correlation id from X-Request-Id header, generated if absent
    jobId       → ingest job id (set during ingest pipeline only)
    queryHash   → SHA-256 of the rewritten query (set during QA pipeline only)
    stage       → current pipeline stage (rewrite / embed / retrieve / ...)

  Pattern tokens:
    %X{key:-default} renders the MDC value, or "default" if absent.
    The default-value trick keeps the field present even for lines that
    happen outside a request (boot, scheduler, health-check) — easier to
    regex in log shipping.
-->
<configuration scan="false">

    <property name="LOG_PATTERN_CONSOLE"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%X{tenant:-none}] [%X{requestId:-none}] [%X{jobId:-}] [%X{queryHash:-}] [stage=%X{stage:-}] %-40.40logger{39} : %m%n%xException"/>

    <appender name="CONSOLE_TEXT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN_CONSOLE}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- JSON encoder — only enabled when LOG_FORMAT=json. We don't depend on
         logstash-logback-encoder to keep the fat-jar small; the JSON layout
         below uses logback's own PatternLayout with explicit field tokens. -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>{
  "ts":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}",
  "level":"%5p",
  "logger":"%logger{40}",
  "thread":"%thread",
  "tenant":"%X{tenant:-}",
  "requestId":"%X{requestId:-}",
  "jobId":"%X{jobId:-}",
  "queryHash":"%X{queryHash:-}",
  "stage":"%X{stage:-}",
  "msg":%msg,
  "exception":"%replace(%xException){'[\r\n]+',' |}"
}%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Audit channel — dedicated appender chain. The audit logger is
         additivity-disabled so audit events NEVER pollute the application
         console (compliance readers should not have to grep past business
         logs). The file appender writes to logs/audit.log (rolling daily,
         90-day retain — see checklist §9 audit retention 6 months, logback
         defaults are 30 days, ops can extend in production by overriding
         maxHistory). The console appender is gated by setting the system
         property AUDIT_TO_CONSOLE=1; we keep it ALWAYS wired and let the
         logback <filter> drop the line when the property is unset, which
         is portable across all logback versions and doesn't need the
         janino conditional plug-in. -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${AUDIT_FILE:-logs/audit.log}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${AUDIT_FILE:-logs/audit.log}.%d{yyyy-MM-dd}.gz</fileNamePattern>
            <maxHistory>90</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <!-- The audit message is already a kv payload — print it
                 verbatim with a timestamp + level prefix. Compliance
                 tooling can split the line on the first space. -->
            <pattern>%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5p %X{audit.tenant:-__global__} %X{audit.actor:-} %X{audit.requestId:-} %X{audit.resource:-} %m%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <appender name="AUDIT_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <!-- Drop everything below INFO unless AUDIT_TO_CONSOLE=1.
                 ThresholdFilter's level is the MIN level to keep; we set
                 it to OFF when the env var is unset and INFO when set. -->
            <level>${AUDIT_TO_CONSOLE:-OFF}</level>
        </filter>
        <encoder>
            <pattern>[audit] %d{HH:mm:ss.SSS} %X{audit.tenant:-__global__} %m%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <logger name="audit" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
        <appender-ref ref="AUDIT_CONSOLE"/>
    </logger>

    <!-- Default: console text. Switch via env var LOG_FORMAT=json. -->
    <root level="INFO">
        <appender-ref ref="${LOG_APPENDER:-CONSOLE_TEXT}"/>
    </root>

    <!-- Our own code at INFO by default; QA at DEBUG when LOG_LEVEL_RAG=DEBUG. -->
    <logger name="io.github.yysf1949.rag" level="${LOG_LEVEL_RAG:-INFO}"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.data.redis" level="WARN"/>

</configuration>