{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Agent Tool Invocations (by outcome)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(agent_tool_invocations_total[5m])",
          "legendFormat": "{{tool}} — {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 30, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "SUCCESS" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "FAILURE" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "HANDOFF_REQUIRED" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "Agent Tool Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(agent_tool_latency_seconds_bucket[5m]))",
          "legendFormat": "P50 {{tool}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(agent_tool_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 {{tool}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, rate(agent_tool_latency_seconds_bucket[5m]))",
          "legendFormat": "P99 {{tool}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2 } }
      }
    },
    {
      "title": "Handoffs (by reason + channel)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "increase(agent_handoffs_total[1h])",
          "legendFormat": "{{reason}} → {{channel}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Idempotency Replays (稳定性指标)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "increase(agent_idempotency_replays_total[1h])",
          "legendFormat": "replays",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Agent Errors (治理层/编排层异常)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(agent_tool_errors_total[5m])",
          "legendFormat": "{{tool}} — {{errorType}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "color": { "mode": "palette-classic" },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 0.1 }] }
        }
      }
    },
    {
      "title": "Tool Invocation Heatmap (success rate %)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "100 * sum by (tool) (rate(agent_tool_invocations_total{outcome=\"SUCCESS\"}[5m])) / sum by (tool) (rate(agent_tool_invocations_total[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "title": "Active Conversations (multi-turn sessions)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "chat_memory_active_conversations",
          "legendFormat": "active sessions",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "orange", "value": 100 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["agent", "rag", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "RAG Agent Observability Dashboard",
  "uid": "rag-agent-observability",
  "version": 1
}
