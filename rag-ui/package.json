{
  "name": "rag-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "RAG admin UI — React 18 + Vite + Tailwind + shadcn/ui. Phase 36-T1 scaffold.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "openapi:gen": "openapi-typescript ../docs/openapi/openapi.json -o ./src/api/schema.d.ts && openapi-typescript-codegen --input ../docs/openapi/openapi.json --output ./src/api/client --client axios"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "axios": "^1.7.7",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "openapi-typescript": "^7.4.2",
    "openapi-typescript-codegen": "^0.29.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
